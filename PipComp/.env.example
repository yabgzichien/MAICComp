# Copy this file to `.env.local` and fill in your real key.
# `.env.local` is gitignored; this `.env.example` is safe to commit.
#
# Get a free Groq key: https://console.groq.com -> API Keys
#
# EXPO_PUBLIC_ vars are readable by the app at runtime (process.env.EXPO_PUBLIC_*).
# NOTE: they are inlined into the JS bundle at build time, so they are NOT secret
# in a shipped app — fine for local dev, but a real product should proxy the key
# through a backend. At runtime the in-app Settings key (expo-secure-store) wins.

# Groq is the PRIMARY provider for every task (vision + text). The default model is
# qwen/qwen3.6-27b — the only vision-capable model Groq currently serves.
EXPO_PUBLIC_GROQ_API_KEY=gsk_your_key_here
# Optional: override the default model
# EXPO_PUBLIC_GROQ_MODEL=qwen/qwen3.6-27b

# Gemini is the FALLBACK: used only when a Groq call fails, and for PDF documents Groq's
# vision model cannot read. Recommended so document import and resilience keep working.
# Get a key: https://aistudio.google.com -> API Keys
# EXPO_PUBLIC_GEMINI_API_KEY=AIza_your_key_here
# Optional: override the default model (defaults to gemini-3.1-flash-lite)
# EXPO_PUBLIC_GEMINI_MODEL=gemini-3.1-flash-lite
