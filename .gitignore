# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build output / caches ────────────────────────────────────────────────────
dist/
build/
out/
web-build/
.next/
.expo/
.expo-shared/
*.tsbuildinfo
next-env.d.ts

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ─── Claude Code workspace & agent memory (private) ───────────────────────────
.claude/

# ─── Internal design bundles / prototypes ─────────────────────────────────────
.design/

# ─── Specs, plans, internal handoff & overview docs (not for the public repo) ──
# (leading **/ so it matches at any depth, e.g. PipComp/docs/superpowers/)
**/docs/superpowers/
HANDOFF.md
handoff.md
functionality_overview.md

# ─── Raw / sensitive data — NEVER publish (real bank transactions, etc.) ──────
dataset/
*.csv

# ─── Scratch notes ────────────────────────────────────────────────────────────
*.txt
Thoughts.md

# ─── Documents (statements, test scans, decks) ───────────────────────────────
*.pdf
*.pptx
*.ppt

# ─── Environment & secrets (the .env.example template stays committed) ────────
.env
.env.*
!.env.example

# ─── Keys / certificates / deploy ─────────────────────────────────────────────
*.keystore
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
.vercel

# ─── Issuer signing secret (rotated 2026-07-12 after the prior key was found
# committed/public; keep the new one untracked from here on — the .example
# stays committed as a template, run tools/issuerKey/generate.js after cloning) ──
PipComp/src/data/issuerKey.ts

# ─── Root allowlist — only the two app folders + README/.gitignore are ever ───
# committed at the repo root (decks, screenshots, scratch exports, etc. stay
# local-only regardless of file type). Must stay last: gitignore evaluates
# rules in order, and negation only re-includes a path excluded above it.
/*
!/PipComp/
!/LenderConsole/
!/README.md
!/.gitignore
