# Groq API key for the AI Assessment Panel (server-side only — do NOT prefix with
# NEXT_PUBLIC_, or it will be bundled into the browser). Reuses the same key
# already configured in PipComp/.env.local as EXPO_PUBLIC_GROQ_API_KEY.
GROQ_API_KEY=

# Optional — defaults to meta-llama/llama-4-scout-17b-16e-instruct if unset.
GROQ_MODEL=

# Optional persistent store for the Policy tab + direct-apply mailbox (lib/kvStore.ts).
# Without these, both fall back to a local .data/*.json file — fine for local dev or any
# persistent (non-serverless) host, but a Vercel serverless function's filesystem is
# ephemeral, so a Vercel deploy needs one of these pairs set or policy edits will silently
# reset between requests. On Vercel: Project -> Storage -> attach a KV or Upstash-for-Redis
# store and these are auto-injected, no manual entry needed. See docs/deploy.md.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative naming used by the current Upstash-for-Redis marketplace integration
# (either pair works — lib/kvStore.ts accepts both):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
