# Groq API key for the AI Assessment Panel (server-side only — do NOT prefix with
# NEXT_PUBLIC_, or it will be bundled into the browser). Reuses the same key
# already configured in PipComp/.env.local as EXPO_PUBLIC_GROQ_API_KEY.
GROQ_API_KEY=

# Optional — defaults to meta-llama/llama-4-scout-17b-16e-instruct if unset.
GROQ_MODEL=
